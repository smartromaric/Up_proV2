# true = POST /v1/auth/*/login (Supabase) même si USE_MOCKS=true
NEXT_PUBLIC_USE_REAL_AUTH=true

NEXT_PUBLIC_APP_NAME=UpJunoo Pro

# Carte live Mapbox (pk.eyJ...) — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Comptes dev server1 (SWAGGER.md) — préremplissage formulaire admin
