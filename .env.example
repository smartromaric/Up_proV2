# API UpJunoo (Swagger — SWAGGER.md)
NEXT_PUBLIC_API_URL=https://api.upjunoo-dev.tech

# true = MSW pour le back-office /api/v2 ; false = API distante
NEXT_PUBLIC_USE_MOCKS=false

# true = POST /v1/auth/*/login (Supabase) même si USE_MOCKS=true
NEXT_PUBLIC_USE_REAL_AUTH=true

NEXT_PUBLIC_APP_NAME=UpJunoo Pro

# Fournisseur cartes (live map, zones, SOS, itinéraires…) : mapbox ou osm
NEXT_PUBLIC_LIVE_MAP_PROVIDER=mapbox

# Mapbox (pk.eyJ...) — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# OpenStreetMap (Leaflet) — optionnel
# NEXT_PUBLIC_OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org

# Comptes dev server1 (SWAGGER.md) — préremplissage formulaire admin
NEXT_PUBLIC_DEV_ADMIN_EMAIL=dev.admin@upjunoo-dev.tech
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=Upjunoo@Dev2026!
